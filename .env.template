# ============================================================
# YT Shorts Agent — Environment Variables
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.
# ============================================================

# --- Google Gemini Flash API ---
GEMINI_API_KEY=

# --- Telegram Bot (failure alerts) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- YouTube OAuth (generated via auth_flow.py) ---
# These are managed via credentials/google_oauth.json and
# credentials/token.json — no env vars needed for OAuth itself.

# --- Supabase Agent Bridge ---
# Required to sync config and video status with the web dashboard.
# Get these from your Supabase project → Settings → API.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# The Supabase auth.users UUID of the user this agent instance serves.
# Find this in the Supabase dashboard → Authentication → Users.
USER_ID=

# Must match TOKEN_ENCRYPTION_KEY in cronus-web/.env.local
# Used to decrypt YouTube OAuth tokens stored in the database.
TOKEN_ENCRYPTION_KEY=
